local function PODPAY_fake_script() -- SuperCoolGuiV2.Content.Menu.Tabs.misc_tab.Frame.Content.TabContent.Content.elementsizing [.Source]
	local script = Instance.new("LocalScript", _U["Content_28"])

	local scrollingFrame = script.Parent
	local layout = scrollingFrame:WaitForChild("UIListLayout")

	local function updateCanvasSize()
		local amountOfElements = 0
		local sizeOfFullCanvasY = 0

