	local script = Instance.new("LocalScript", _U["SuperCoolGuiV2"])

	local TweenService = game:GetService("TweenService")
	local screenGui = script.Parent

	local TWEEN_INFO = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local SWITCH_INFO = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local CLICK_INFO = TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	local HOVER_OFFSET_SCALE = -0.2
	local SHRINK_FACTOR = 0.8

	local activeTabButton = nil
	local activeLayoutIndex = 1

	local function setupButtonEffects(button: GuiButton)
		if not button:GetAttribute("hoverEffect") and not button:GetAttribute("shrinkEffect") and not button:GetAttribute("highlightImageEffect") then return end
		local originalPosition = button.Position
		local originalSize = button.Size

		local hoverPosition = originalPosition + UDim2.new(
			0, 0, 
			button.Size.Y.Scale * HOVER_OFFSET_SCALE, 
			button.Size.Y.Offset * HOVER_OFFSET_SCALE
		)

		local clickedSize = UDim2.new(
			button.Size.X.Scale * SHRINK_FACTOR,
			button.Size.X.Offset * SHRINK_FACTOR,
			button.Size.Y.Scale * SHRINK_FACTOR,
			button.Size.Y.Offset * SHRINK_FACTOR
		)

		if button:GetAttribute("hoverEffect") then
			button.MouseEnter:Connect(function()
				TweenService:Create(button, TWEEN_INFO, {Position = hoverPosition}):Play()
			end)

			button.MouseLeave:Connect(function()
				TweenService:Create(button, TWEEN_INFO, {Position = originalPosition}):Play()
			end)
		end

		if button:GetAttribute("highlightImageEffect") and button:IsA("ImageButton") then
			local originalColour = button:GetAttribute("baseColor") or button:GetAttribute("baseColour") or button.ImageColor3
			local highlightColour = button:GetAttribute("highlightColor") or button:GetAttribute("highlightColour") or Color3.fromRGB(255, 255, 255)

			button.MouseEnter:Connect(function()
				TweenService:Create(button, TWEEN_INFO, {ImageColor3 = highlightColour}):Play()
			end)

			button.MouseLeave:Connect(function()
				if activeTabButton ~= button then
					TweenService:Create(button, TWEEN_INFO, {ImageColor3 = originalColour}):Play()
				end
			end)
		end

		if button:GetAttribute("shrinkEffect") then
			button.MouseButton1Down:Connect(function()
				TweenService:Create(button, CLICK_INFO, {Size = clickedSize}):Play()
				task.wait(0.05)
				TweenService:Create(button, CLICK_INFO, {Size = originalSize}):Play()
			end)
		end	

		button.MouseLeave:Connect(function()
			TweenService:Create(button, CLICK_INFO, {Size = originalSize}):Play()
		end)
	end

	local function setupTabSwitchingSystem()
		local contentFrame = screenGui:WaitForChild("Content", 5)
		local menu = contentFrame and contentFrame:WaitForChild("Menu", 5)
		if not menu then return end

		local tabsContainer = menu:WaitForChild("Tabs")

		local menuSide = menu:FindFirstChild("MenuSide", true)
		if not menuSide then return end

		local contentScrollingFrame = menuSide:WaitForChild("Content")

		local tabConnections = {
			[contentScrollingFrame:WaitForChild("info_tab"):WaitForChild("Button")] = 1,
			[contentScrollingFrame:WaitForChild("settings_tab"):WaitForChild("Button")] = 2,
			[contentScrollingFrame:WaitForChild("misc_tab"):WaitForChild("Button")] = 3,
			[menuSide:WaitForChild("internalsettings_tab"):WaitForChild("Button")] = 4
		}

		local function switchToTab(clickedButton, layoutOrderIndex, isResizeEvent)
			local targetTabFrame = tabsContainer:FindFirstChildOfClass("Frame")
			local singleTabPixelHeight = targetTabFrame and targetTabFrame.AbsoluteSize.Y or 360

			local targetPixelY = (layoutOrderIndex - 1) * singleTabPixelHeight

			activeLayoutIndex = layoutOrderIndex

			-- If it's a window resize event, update instantly without animation lag
			local infoToUse = isResizeEvent and TweenInfo.new(0) or SWITCH_INFO

			TweenService:Create(tabsContainer, infoToUse, {
				CanvasPosition = Vector2.new(0, targetPixelY)
			}):Play()

			if not isResizeEvent then
				local oldActiveButton = activeTabButton
				activeTabButton = clickedButton

				for button, _ in pairs(tabConnections) do
					local baseColor = button:GetAttribute("baseColor") or button:GetAttribute("baseColour") or Color3.fromRGB(160, 160, 160)
					local highlightColor = button:GetAttribute("highlightColor") or button:GetAttribute("highlightColour") or Color3.fromRGB(255, 255, 255)

					if button == clickedButton then
						TweenService:Create(button, SWITCH_INFO, {ImageColor3 = highlightColor}):Play()
					elseif button == oldActiveButton then
						TweenService:Create(button, SWITCH_INFO, {ImageColor3 = baseColor}):Play()
					end
				end
			end
		end

		for button, index in pairs(tabConnections) do
			button.MouseButton1Click:Connect(function()
				switchToTab(button, index, false)
			end)
		end

		-- Automatically adjust the canvas position whenever the scale/size changes
		tabsContainer:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
			if activeTabButton then
				switchToTab(activeTabButton, activeLayoutIndex, true)
			end
		end)

		local defaultButton = contentScrollingFrame.info_tab.Button
		if tabConnections[defaultButton] then
			tabsContainer.CanvasPosition = Vector2.new(0, 0)
			switchToTab(defaultButton, tabConnections[defaultButton], false)
		end
	end

	local function scanHierarchy(parent: Instance)
		for _, child in ipairs(parent:GetChildren()) do
			if child:IsA("GuiButton") then
				setupButtonEffects(child)
			end
			scanHierarchy(child)
		end
	end

	scanHierarchy(screenGui)
	setupTabSwitchingSystem()

	screenGui.DescendantAdded:Connect(function(descendant)
		if descendant:IsA("GuiButton") then
			setupButtonEffects(descendant)
		end
	end)
end
coroutine.wrap(VISOIJ_fake_script)()

