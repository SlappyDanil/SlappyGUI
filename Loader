local function HIGRRQ_fake_script() -- SuperCoolGuiV2.Content.Menu.Tabs.info_tab.Frame.Content.TabContent.Content.elementsizing [.Source]
	local script = Instance.new("LocalScript", _U["Content_6"])

	local scrollingFrame = script.Parent
	local layout = scrollingFrame:WaitForChild("UIListLayout")

	local function updateCanvasSize()
		local amountOfElements = 0
		local sizeOfFullCanvasY = 0

		local sizeOfHalfCanvasY = 0
		local amountOfHalfElements = 2

		for _, child in ipairs(scrollingFrame:GetChildren()) do
			if child:IsA("Frame") then
				amountOfElements = amountOfElements + 1
				sizeOfFullCanvasY += child.AbsoluteSize.Y
			end

			if child:IsA("Frame") and child.LayoutOrder <= amountOfHalfElements then
				sizeOfHalfCanvasY += child.AbsoluteSize.Y
			end
		end

		sizeOfHalfCanvasY += (amountOfHalfElements - 1) * layout.Padding.Offset
		sizeOfFullCanvasY += (amountOfElements - 1) * layout.Padding.Offset

		if scrollingFrame.AbsoluteSize.X < 350 then
			scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, sizeOfFullCanvasY)
		else
			scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, sizeOfHalfCanvasY)
		end
	end

	scrollingFrame.Changed:Connect(function(property)
		if property == "AbsoluteSize" then
			updateCanvasSize()
		end
	end)

	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		updateCanvasSize()
	end)

	updateCanvasSize()
end
coroutine.wrap(HIGRRQ_fake_script)()

local function TVIOGY_fake_script() -- SuperCoolGuiV2.Content.Menu.Tabs.info_tab.Frame.Content.TabContent.Content.user_info.Frame.Content.Section.Content.Element.Frame.Content.Element.Text.updateRunTime [.Source]
	local script = Instance.new("LocalScript", _U["Text"])

	local textLabel = script.Parent
	local startTime = os.clock()

	while true do
		local elapsedTime = os.clock() - startTime

		local hours = math.floor(elapsedTime / 3600)
		local minutes = math.floor((elapsedTime % 3600) / 60)
		local seconds = math.floor(elapsedTime % 60)

		textLabel.Text = string.format("Run time: %02d:%02d:%02d", hours, minutes, seconds)

		task.wait(1)
	end
end
