local function ZJIOES_fake_script() -- SuperCoolGuiV2.sliders [.Source]
	local script = Instance.new("LocalScript", _U["SuperCoolGuiV2"])

	local UIS = game:GetService("UserInputService")
	local screenGui = script.Parent

	local function setupSliders(root)
		for _, child in pairs(root:GetChildren()) do
			if child:IsA("Frame") and child.Name == "Slider" then
				local sliderFrame = child
				local parentElement = sliderFrame.Parent
				local valueBox = parentElement:FindFirstChild("Value")

				if valueBox and valueBox:IsA("TextBox") then
					local fill = sliderFrame:FindFirstChild("Fill")
					local handle = sliderFrame:FindFirstChild("Handle")

					-- Ensure configuration attributes exist on the TextBox
					if valueBox:GetAttribute("min") == nil then valueBox:SetAttribute("min", 0) end
					if valueBox:GetAttribute("max") == nil then valueBox:SetAttribute("max", 100) end
					if valueBox:GetAttribute("value") == nil then valueBox:SetAttribute("value", valueBox:GetAttribute("min")) end

					local function updateSliderVisuals()
						local min = valueBox:GetAttribute("min") or 0
						local max = valueBox:GetAttribute("max") or 100
						local currentVal = valueBox:GetAttribute("value") or min

						local percent = math.clamp((currentVal - min) / (max - min), 0, 1)

						if fill then
							fill.Size = UDim2.new(percent, fill.Size.X.Offset, fill.Size.Y.Scale, fill.Size.Y.Offset)
						end
						if handle then
							handle.Position = UDim2.new(percent, handle.Position.X.Offset, handle.Position.Y.Scale, handle.Position.Y.Offset)
						end

						valueBox.Text = tostring(math.round(currentVal))
					end

					local dragging = false

					local function snapToMouse()
						local mousePos = UIS:GetMouseLocation().X
						local sliderLeft = sliderFrame.AbsolutePosition.X
						local sliderWidth = sliderFrame.AbsoluteSize.X

						local percent = math.clamp((mousePos - sliderLeft) / sliderWidth, 0, 1)

						local min = valueBox:GetAttribute("min") or 0
						local max = valueBox:GetAttribute("max") or 100
						local newValue = math.round(min + (percent * (max - min)))

						valueBox:SetAttribute("value", newValue)
					end

					sliderFrame.InputBegan:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = true
							snapToMouse()
						end
					end)

					if handle then
						handle.InputBegan:Connect(function(input)
							if input.UserInputType == Enum.UserInputType.MouseButton1 then
								dragging = true
							end
						end)
					end

					UIS.InputChanged:Connect(function(input)
						if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
							snapToMouse()
						end
					end)

					UIS.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = false
						end
					end)

					valueBox.FocusLost:Connect(function()
						local num = tonumber(valueBox.Text)
						local min = valueBox:GetAttribute("min") or 0
						local max = valueBox:GetAttribute("max") or 100

						if num then
							num = math.clamp(num, min, max)
							valueBox:SetAttribute("value", num)
						else
							valueBox.Text = tostring(valueBox:GetAttribute("value"))
						end
					end)

					valueBox:GetAttributeChangedSignal("value"):Connect(updateSliderVisuals)
					valueBox:GetAttributeChangedSignal("min"):Connect(updateSliderVisuals)
					valueBox:GetAttributeChangedSignal("max"):Connect(updateSliderVisuals)

					updateSliderVisuals()
				end
			end
			setupSliders(child)
		end
	end

	setupSliders(screenGui)
end
coroutine.wrap(ZJIOES_fake_script)()

