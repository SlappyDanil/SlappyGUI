local mainFolder = "Slappy"
local iconsFolder = mainFolder .. "/Icons"

local function ensureFolderPath(fullPath: string)
	if not isfolder or not makefolder then return end 
	local currentPath = ""
	for folderName in string.gmatch(fullPath, "[^/]+") do 
		currentPath = (currentPath == "") and folderName or (currentPath .. "/" .. folderName)
		if not isfolder(currentPath) then makefolder(currentPath) end
	end
end

local function loadUiIcon(iconName: string, fallbackId: string)
	local localFilePath = iconsFolder .. "/" .. iconName .. ".png"
	-- Automatically generates the GitHub raw download URL
	local downloadUrl = "https://raw.githubusercontent.com/SlappyDanil/SlappyGUI/refs/heads/main/Icons/" .. iconName .. ".png"

	if isfile and writefile and getcustomasset then
		ensureFolderPath(iconsFolder)
		if isfile(localFilePath) then return getcustomasset(localFilePath) end
		local success, content = pcall(function() return game:HttpGet(downloadUrl) end)
		if success and content and not string.find(content, "404") then
			writefile(localFilePath, content)
			return getcustomasset(localFilePath)
		end
	end
	return "rbxassetid://" .. fallbackId
end

