local function DAEBFB_fake_script() -- SuperCoolGuiV2.Content.Menu.Tabs.misc_tab.Frame.Content.TabContent.Content.emotes.Frame.Content.Section.Content.emotes [.Source]
	local script = Instance.new("LocalScript", _U["Content_41"])

	local content = script.Parent
	local Players = game:GetService("Players")
	local player = Players.LocalPlayer

	local currentTrack = nil
	local moveConnection = nil
	local stateConnection = nil

	local validButtons = {}   -- Stores list of found buttons and their IDs: { {btn = Instance, id = number}, ... }
	local loadedTracks = {}   -- Stores active animation tracks mapped to buttons: [button] = AnimationTrack

	-- 1. Scan the UI container once at startup to find all valid emote buttons
	for _, frame in ipairs(content:GetChildren()) do
		if frame:IsA("GuiObject") then
			-- Safe lookups prevent the script from freezing if there are UIListLayouts inside 'content'
			local frameUI = frame:FindFirstChild("Frame")
			local contentUI = frameUI and frameUI:FindFirstChild("Content")
			local elementUI = contentUI and contentUI:FindFirstChild("Element")
			local btn = elementUI and elementUI:FindFirstChild("Click")

			if btn then
				local btnAnimId = btn:GetAttribute("id")
				if btnAnimId then
					table.insert(validButtons, {btn = btn, id = btnAnimId})
				end
			end
		end
	end

	-- Helper function to safely stop the currently active emote
	local function stopCurrentEmote()
		if currentTrack and currentTrack.IsPlaying then
			currentTrack:Stop()
		end
		currentTrack = nil
	end

	-- 2. Handle updating tracks and physics listeners whenever the player spawns/respawns
	local function onCharacterAdded(character)
		-- Disconnect old character listeners to prevent memory leaks
		if moveConnection then moveConnection:Disconnect() end
		if stateConnection then stateConnection:Disconnect() end
		stopCurrentEmote()
		table.clear(loadedTracks)

		local humanoid = character:WaitForChild("Humanoid")
		local animator = humanoid:WaitForChild("Animator")

		-- A single shared listener handles canceling ANY playing emote when the player moves
		moveConnection = humanoid:GetPropertyChangedSignal("MoveDirection"):Connect(function()
			if humanoid.MoveDirection.Magnitude > 0 then
				stopCurrentEmote()
			end
		end)

		-- A single shared listener handles canceling emotes when jumping/falling
		stateConnection = humanoid.StateChanged:Connect(function(_, newState)
			if newState == Enum.HumanoidStateType.Jumping or newState == Enum.HumanoidStateType.Freefall then
				stopCurrentEmote()
			end
		end)

		-- Load all animations onto the new character's animator
		for _, data in ipairs(validButtons) do
			local animation = Instance.new("Animation")
			animation.AnimationId = "rbxassetid://" .. tostring(data.id)

			local track = animator:LoadAnimation(animation)
			track.Priority = Enum.AnimationPriority.Action
			track.Looped = false

			loadedTracks[data.btn] = track
		end
	end

	-- 3. Set up click bindings once globally
	for _, data in ipairs(validButtons) do
		data.btn.MouseButton1Click:Connect(function()
			local track = loadedTracks[data.btn]
			if track then
				-- If a different emote is already running, cut it off first
				if currentTrack and currentTrack ~= track then
					stopCurrentEmote()
				end

				track:Play()
				currentTrack = track
			end
		end)
	end

	-- Initialize for current character and listen for future deaths/respawns
	if player.Character then onCharacterAdded(player.Character) end
	player.CharacterAdded:Connect(onCharacterAdded)
end
coroutine.wrap(DAEBFB_fake_script)()

local function RPHTSY_fake_script() -- SuperCoolGuiV2.Content.Menu.sizeBox.menusizing [.Source]
	local script = Instance.new("LocalScript", _U["sizeBox"])

	local sizebox = script.Parent
	local mainFrame = sizebox.Parent
	local UIS = game:GetService("UserInputService")

	local dragging = false
	local dragStartSize = Vector2.new(0, 0)
	local dragStartMousePos = Vector2.new(0, 0)
	local initialTopLeft = Vector2.new(0, 0)

	local MIN_SIZE = Vector2.new(300, 200)
	local MAX_SIZE = Vector2.new(832, 517)

	sizebox.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStartSize = mainFrame.AbsoluteSize
			dragStartMousePos = UIS:GetMouseLocation()
			initialTopLeft = mainFrame.AbsolutePosition
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local currentMousePos = UIS:GetMouseLocation()
			local delta = currentMousePos - dragStartMousePos

			local newWidth = math.clamp(dragStartSize.X + delta.X, MIN_SIZE.X, MAX_SIZE.X)
			local newHeight = math.clamp(dragStartSize.Y + delta.Y, MIN_SIZE.Y, MAX_SIZE.Y)

			local parentGui = mainFrame.Parent
			local parentAbsolutePosition = (parentGui:IsA("GuiObject") and parentGui.AbsolutePosition) or Vector2.new(0, 0)

			local targetCenterX = initialTopLeft.X + (newWidth / 2) - parentAbsolutePosition.X
			local targetCenterY = initialTopLeft.Y + (newHeight / 2) - parentAbsolutePosition.Y

			mainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
			mainFrame.Position = UDim2.new(0, targetCenterX, 0, targetCenterY)
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
end
coroutine.wrap(RPHTSY_fake_script)()

local function PBWDHQ_fake_script() -- SuperCoolGuiV2.Content.Menu.corner.corneropening [.Source]
	local script = Instance.new("LocalScript", _U["corner"])

	local corner = script.Parent
	local main = corner.Parent
	local topBar = main:WaitForChild("Frame1")

	local uis = game:GetService("UserInputService")		
	local ts = game:GetService("TweenService")

	local ti = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	corner.MouseEnter:Connect(function()
		ts:Create(topBar, ti, {
			Size = UDim2.new(1, -50, 0, 25),
			Position = UDim2.new(0, 45, 0, 5)
		}):Play()
	end)

	corner.MouseLeave:Connect(function()
		ts:Create(topBar, ti, {
			Size = UDim2.new(1, -10, 0, 25),
			Position = UDim2.new(0, 5, 0, 5)
		}):Play()
	end)

	corner.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			ts:Create(topBar, ti, {
				Size = UDim2.new(1, -50, 0, 25),
				Position = UDim2.new(0, 45, 0, 5)
			}):Play()
		end
	end)

	corner.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			ts:Create(topBar, ti, {
				Size = UDim2.new(1, -10, 0, 25),
				Position = UDim2.new(0, 5, 0, 5)
			}):Play()
		end
	end)
end
coroutine.wrap(PBWDHQ_fake_script)()
